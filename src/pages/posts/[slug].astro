---
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {

  return Object.values({

  ...import.meta.glob("/src/content/journal/*.md", {
    eager: true,
  }),

  ...import.meta.glob("/src/content/translation/*.md", {
    eager: true,
  }),

  ...import.meta.glob("/src/content/notes/*.md", {
    eager: true,
  }),

})

  .map((post: any) => {

    const slug = post.file
      .split("/")
      .pop()
      .replace(".md", "");

    return {
      params: { slug },
      props: { post },
    };

  });

}

const { post } = Astro.props;

if (post.frontmatter.draft) {
  return Astro.redirect("/");
}

const {
  title,
  date,
} = post.frontmatter;

function formatDate(date: string) {

  const d = new Date(date);

  const day = String(d.getDate()).padStart(2, "0");
  const month = String(d.getMonth() + 1).padStart(2, "0");
  const year = String(d.getFullYear()).slice(-2);

  return `${day}.${month}.${year}`;
}

const Content = post.default;

const allPosts = Object.values({

  ...import.meta.glob("/src/content/journal/*.md", {
    eager: true,
  }),

  ...import.meta.glob("/src/content/translation/*.md", {
    eager: true,
  }),

  ...import.meta.glob("/src/content/notes/*.md", {
    eager: true,
  }),

});


allPosts.sort((a: any, b: any) => {

  return (
    new Date(b.frontmatter.date).getTime() -
    new Date(a.frontmatter.date).getTime()
  );

});

const currentSlug = post.file
  .split("/")
  .pop()
  .replace(".md", "");

const currentIndex = allPosts.findIndex(
  (p: any) => {

    const slug = p.file
      .split("/")
      .pop()
      .replace(".md", "");

    return slug === currentSlug;

  }
);

const nextPost =
  allPosts[currentIndex - 1];

const previousPost =
  allPosts[currentIndex + 1];

function getSlug(post: any) {

  return post.file
    .split("/")
    .pop()
    .replace(".md", "");

}

function getCategory(post: any) {

  if (post.file.includes("/journal/")) {
    return "journal";
  }

  if (post.file.includes("/translation/")) {
    return "translation";
  }

  return "notes";
}
---

<BaseLayout>

  <main class="article-page">

    <div class="article-topbar">

      <a href="/">
        too many open tabs
      </a>

      <a href="/">
        index
      </a>

    </div>

    <article>

      <div class="article-meta">

        <span>
          {formatDate(date)}
        </span>

        <span>
          / {getCategory(post)}
        </span>

      </div>

      <h1>
        {title}
      </h1>

      {post.frontmatter.tags && (

  <div class="article-tags">

    {post.frontmatter.tags.map(
      (tag: string) => (

        <a href={`/tags/${tag}`}>
          #{tag}
        </a>

      )
    )}

  </div>

)}

<div class="article-content">
  <Content />
</div>

    </article>

    <footer class="article-footer">

  <div class="article-pagination">

    <div>

      {previousPost && (

        <a
          href={`/posts/${getSlug(previousPost)}`}
        >

          ←

        </a>

      )}

    </div>

    <div>

      {nextPost && (

        <a
          href={`/posts/${getSlug(nextPost)}`}
        >

          →

        </a>

      )}

    </div>

  </div>

</footer>

  </main>

</BaseLayout>